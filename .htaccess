#AuthType Basic
#AuthName "Developer Login"
#AuthUserFile /data/web/virtuals/385273/virtual/www/domains/dev2.blueorcawebsites.eu/.htpasswd
#Require valid-user

RewriteEngine On
RewriteBase /

# Security: Prevent access to hidden files (including .env, .git, etc.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Deny access to sensitive file types
<FilesMatch "\.(yml|yaml|json|lock|log|md|sh|sql|bak|env)$">
    Require all denied
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self';"
</IfModule>

# Cache: long-lived for versioned static assets, no-cache for HTML
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                  "access plus 1 year"
    ExpiresByType application/javascript    "access plus 1 year"
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType font/woff                 "access plus 1 year"
    ExpiresByType text/html                 "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|webp|svg|woff2|woff)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>


