#AuthType Basic
#AuthName "Developer Login"
#AuthUserFile /data/web/virtuals/385273/virtual/www/domains/dev2.blueorcawebsites.eu/.htpasswd
#Require valid-user

RewriteEngine On
RewriteBase /

# Security: Prevent access to hidden files (including .env, .git, etc.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Deny access to sensitive file types
<FilesMatch "\.(yml|yaml|json|lock|log|md|sh|sql|bak|env)$">
    Require all denied
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Browser caching
<IfModule mod_headers.c>
    # CSS, images, fonts → long-term cache (1 year)
    <FilesMatch "\.(css|webp|avif|jpg|jpeg|png|gif|ico|woff|woff2|ttf|eot|svg)$">
        Header always set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # JS → short-term cache (no content hash)
    <FilesMatch "\.js$">
        Header always set Cache-Control "public, max-age=360000, must-revalidate"
    </FilesMatch>

    # HTML → revalidate every hour
    <FilesMatch "\.html$">
        Header always set Cache-Control "public, max-age=360000, must-revalidate"
    </FilesMatch>
</IfModule>


