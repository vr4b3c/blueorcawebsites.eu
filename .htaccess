#AuthType Basic
#AuthName "Developer Login"
#AuthUserFile /data/web/virtuals/385273/virtual/www/domains/dev2.blueorcawebsites.eu/.htpasswd
#Require valid-user

RewriteEngine On
RewriteBase /

# Security: Prevent access to hidden files (including .env, .git, etc.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Deny access to sensitive file types
<FilesMatch "\.(yml|yaml|json|lock|log|md|sh|sql|bak|env)$">
    Require all denied
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# DEV: disable all caching
<IfModule mod_headers.c>
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
</IfModule>


